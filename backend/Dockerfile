FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Pinned to match the Poetry that maintains poetry.lock locally (2.x). A 1.x image cannot
# read a lock file generated by Poetry 2.x (it reports the lock as incompatible / "changed
# significantly"), so the versions must stay aligned whenever deps are added via `poetry add`.
RUN pip install poetry==2.3.2

COPY pyproject.toml poetry.lock* ./

ENV POETRY_REQUESTS_TIMEOUT=1000

RUN poetry config virtualenvs.create false \
    && poetry install --no-interaction --no-ansi

COPY . .

EXPOSE 8000 8001

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]