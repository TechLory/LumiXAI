# Copy this file to ".env.local" and adjust the values for your machine.

# Host ports
LUMIXAI_FRONTEND_PORT=3000
LUMIXAI_BACKEND_PORT=8000
LUMIXAI_DOCS_PORT=8001

# Backend runtime
HF_TOKEN=
LUMIXAI_DEFAULT_DEVICE=auto

# GPU container visibility (used with docker-compose.gpu.yml)
# Examples: all, 0, 1, 0,1
LUMIXAI_VISIBLE_GPUS=all
